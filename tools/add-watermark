    <script>
        const addWatermarkBtn = document.getElementById('addWatermarkBtn');
        const pdfInput = document.getElementById('pdfInput');
        const watermarkType = document.getElementById('watermarkType');
        const textWatermarkGroup = document.getElementById('textWatermarkGroup');
        const imageWatermarkGroup = document.getElementById('imageWatermarkGroup');
        const watermarkText = document.getElementById('watermarkText');
        const fontSize = document.getElementById('fontSize');
        const fontFamily = document.getElementById('fontFamily');
        const imageInput = document.getElementById('imageInput');
        const imagePreview = document.getElementById('imagePreview');
        const previewImg = document.getElementById('previewImg');
        const watermarkColor = document.getElementById('watermarkColor');
        const opacity = document.getElementById('opacity');
        const opacityValue = document.getElementById('opacityValue');
        const rotation = document.getElementById('rotation');
        const rotationValue = document.getElementById('rotationValue');
        const position = document.getElementById('position');
        const customPositionGroup = document.getElementById('customPositionGroup');
        const customX = document.getElementById('customX');
        const customY = document.getElementById('customY');
        const watermarkScope = document.getElementById('watermarkScope');
        const pageRangeGroup = document.getElementById('pageRangeGroup');
        const pageRange = document.getElementById('pageRange');
        const fileInfo = document.getElementById('fileInfo');
        const fileInfoText = document.getElementById('fileInfoText');
        const pageInfo = document.getElementById('pageInfo');
        const resultDiv = document.getElementById('result');
        
        let currentPDFData = null;
        let totalPages = 0;
        let watermarkImageData = null;
        
        // Show/hide watermark type groups
        watermarkType.addEventListener('change', () => {
            if (watermarkType.value === 'text') {
                textWatermarkGroup.style.display = 'block';
                imageWatermarkGroup.style.display = 'none';
            } else {
                textWatermarkGroup.style.display = 'none';
                imageWatermarkGroup.style.display = 'block';
            }
        });
        
        // Update opacity display
        opacity.addEventListener('input', () => {
            opacityValue.textContent = opacity.value + '%';
        });
        
        // Update rotation display
        rotation.addEventListener('input', () => {
            rotationValue.textContent = rotation.value + '°';
        });
        
        // Show/hide custom position
        position.addEventListener('change', () => {
            if (position.value === 'custom') {
                customPositionGroup.style.display = 'flex';
            } else {
                customPositionGroup.style.display = 'none';
            }
        });
        
        // Show/hide page range
        watermarkScope.addEventListener('change', () => {
            if (watermarkScope.value === 'range') {
                pageRangeGroup.style.display = 'block';
            } else {
                pageRangeGroup.style.display = 'none';
            }
        });
        
        // Handle image upload
        imageInput.addEventListener('change', (e) => {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(event) {
                    watermarkImageData = event.target.result;
                    previewImg.src = watermarkImageData;
                    imagePreview.style.display = 'block';
                };
                reader.readAsDataURL(file);
            }
        });
        
        // Load PDF when file is selected
        pdfInput.addEventListener('change', async () => {
            const file = pdfInput.files[0];
            if (file) {
                try {
                    const arrayBuffer = await file.arrayBuffer();
                    currentPDFData = arrayBuffer;
                    
                    const { PDFDocument } = PDFLib;
                    const pdfDoc = await PDFDocument.load(arrayBuffer);
                    totalPages = pdfDoc.getPageCount();
                    
                    const fileSize = formatFileSize(file.size);
                    const fileName = file.name;
                    fileInfoText.textContent = `${fileName} (${fileSize})`;
                    pageInfo.innerHTML = `Total pages: ${totalPages}`;
                    fileInfo.style.display = 'block';
                    resultDiv.innerHTML = '';
                    
                    showAlert(`PDF loaded successfully. ${totalPages} page(s) ready for watermarking.`, 'success');
                } catch (error) {
                    console.error('Error loading PDF:', error);
                    showAlert('Error loading PDF. Please ensure it\'s a valid file.', 'error');
                }
            } else {
                fileInfo.style.display = 'none';
                currentPDFData = null;
                totalPages = 0;
            }
        });
        
        // Parse page range
        function parsePageRange(rangeStr, totalPages) {
            if (!rangeStr.trim()) return [];
            
            const pages = new Set();
            const parts = rangeStr.split(',');
            
            for (const part of parts) {
                part = part.trim();
                if (part.includes('-')) {
                    const [start, end] = part.split('-').map(n => parseInt(n.trim()));
                    if (isNaN(start) || isNaN(end)) continue;
                    for (let i = start; i <= end; i++) {
                        if (i >= 1 && i <= totalPages) pages.add(i - 1);
                    }
                } else {
                    const page = parseInt(part);
                    if (!isNaN(page) && page >= 1 && page <= totalPages) pages.add(page - 1);
                }
            }
            
            return Array.from(pages).sort((a, b) => a - b);
        }
        
        // Get pages to watermark
        function getPagesToWatermark(scope, totalPages, rangeStr) {
            switch(scope) {
                case 'all':
                    return Array.from({length: totalPages}, (_, i) => i);
                case 'first':
                    return totalPages > 0 ? [0] : [];
                case 'last':
                    return totalPages > 0 ? [totalPages - 1] : [];
                case 'range':
                    return parsePageRange(rangeStr, totalPages);
                default:
                    return Array.from({length: totalPages}, (_, i) => i);
            }
        }
        
        // Get position coordinates
        function getPosition(positionType, pageWidth, pageHeight, customXVal, customYVal) {
            switch(positionType) {
                case 'center':
                    return { x: pageWidth / 2, y: pageHeight / 2 };
                case 'topleft':
                    return { x: 50, y: pageHeight - 50 };
                case 'topright':
                    return { x: pageWidth - 50, y: pageHeight - 50 };
                case 'bottomleft':
                    return { x: 50, y: 50 };
                case 'bottomright':
                    return { x: pageWidth - 50, y: 50 };
                case 'custom':
                    return { x: customXVal, y: pageHeight - customYVal };
                default:
                    return { x: pageWidth / 2, y: pageHeight / 2 };
            }
        }
        
        // Add watermark to PDF
        async function addWatermarkToPDF() {
            if (!currentPDFData) {
                showAlert('Please select a PDF file first', 'error');
                return;
            }
            
            const type = watermarkType.value;
            
            if (type === 'text' && !watermarkText.value.trim()) {
                showAlert('Please enter watermark text', 'error');
                return;
            }
            
            if (type === 'image' && !watermarkImageData) {
                showAlert('Please select a watermark image', 'error');
                return;
            }
            
            const scope = watermarkScope.value;
            const rangeStr = pageRange.value;
            
            if (scope === 'range' && !rangeStr.trim()) {
                showAlert('Please enter a page range', 'error');
                return;
            }
            
            try {
                addWatermarkBtn.disabled = true;
                addWatermarkBtn.textContent = 'Adding Watermark...';
                resultDiv.innerHTML = '<div class="loader"></div> Adding watermark to PDF... This may take a moment.';
                
                const { PDFDocument, rgb, StandardFonts, degrees } = PDFLib;
                const pdfDoc = await PDFDocument.load(currentPDFData);
                const pages = pdfDoc.getPages();
                const pagesToWatermark = getPagesToWatermark(scope, totalPages, rangeStr);
                
                if (pagesToWatermark.length === 0) {
                    throw new Error('No pages selected for watermarking');
                }
                
                const opacityValue_num = parseInt(opacity.value) / 100;
                const rotationValue_num = parseInt(rotation.value);
                const positionType = position.value;
                const customXVal = parseInt(customX.value) || 300;
                const customYVal = parseInt(customY.value) || 400;
                
                for (const pageIndex of pagesToWatermark) {
                    const page = pages[pageIndex];
                    const { width, height } = page.getSize();
                    
                    const pos = getPosition(positionType, width, height, customXVal, customYVal);
                    
                    if (type === 'text') {
                        // Add text watermark
                        let font;
                        const fontName = fontFamily.value;
                        if (fontName === 'Helvetica') font = await pdfDoc.embedFont(StandardFonts.Helvetica);
                        else if (fontName === 'TimesRoman') font = await pdfDoc.embedFont(StandardFonts.TimesRoman);
                        else font = await pdfDoc.embedFont(StandardFonts.Courier);
                        
                        const colorHex = watermarkColor.value;
                        const r = parseInt(colorHex.slice(1,3), 16) / 255;
                        const g = parseInt(colorHex.slice(3,5), 16) / 255;
                        const b = parseInt(colorHex.slice(5,7), 16) / 255;
                        
                        const text = watermarkText.value;
                        const size = parseInt(fontSize.value);
                        
                        page.drawText(text, {
                            x: pos.x - (text.length * size * 0.3) / 2,
                            y: pos.y,
                            size: size,
                            font: font,
                            color: rgb(r, g, b),
                            opacity: opacityValue_num,
                            rotate: degrees(rotationValue_num)
                        });
                    } else {
                        // Add image watermark
                        let image;
                        if (watermarkImageData.includes('png')) {
                            image = await pdfDoc.embedPng(watermarkImageData);
                        } else {
                            image = await pdfDoc.embedJpg(watermarkImageData);
                        }
                        
                        const imgWidth = image.width;
                        const imgHeight = image.height;
                        
                        // Scale image to reasonable size (max 200px)
                        const maxSize = 150;
                        let drawWidth = imgWidth;
                        let drawHeight = imgHeight;
                        
                        if (imgWidth > maxSize || imgHeight > maxSize) {
                            const scale = Math.min(maxSize / imgWidth, maxSize / imgHeight);
                            drawWidth = imgWidth * scale;
                            drawHeight = imgHeight * scale;
                        }
                        
                        page.drawImage(image, {
                            x: pos.x - drawWidth / 2,
                            y: pos.y - drawHeight / 2,
                            width: drawWidth,
                            height: drawHeight,
                            opacity: opacityValue_num,
                            rotate: degrees(rotationValue_num)
                        });
                    }
                }
                
                const pdfBytes = await pdfDoc.save();
                const blob = new Blob([pdfBytes], { type: 'application/pdf' });
                const url = URL.createObjectURL(blob);
                const originalName = pdfInput.files[0].name.replace('.pdf', '');
                
                resultDiv.innerHTML = `
                    <div class="alert alert-success" style="margin-bottom: 1rem;">✅ Watermark added successfully to ${pagesToWatermark.length} page(s)!</div>
                    <a href="${url}" download="${originalName}_watermarked.pdf" class="download-link">📥 Download Watermarked PDF</a>
                    <p style="margin-top: 1rem; font-size: 0.875rem; color: var(--text-muted);">✓ Watermarked locally - Your file never left your device</p>
                    <p style="margin-top: 0.5rem; font-size: 0.875rem; color: var(--text-muted);">✓ ${pagesToWatermark.length} page(s) watermarked</p>
                `;
                
                showAlert(`Watermark added successfully to ${pagesToWatermark.length} page(s)!`, 'success');
            } catch (error) {
                console.error(error);
                resultDiv.innerHTML = `<div class="alert alert-error">Error: ${error.message || 'Failed to add watermark. Please try again.'}</div>`;
                showAlert('Failed to add watermark. Please try again.', 'error');
            } finally {
                addWatermarkBtn.disabled = false;
                addWatermarkBtn.textContent = 'Add Watermark to PDF';
            }
        }
        
        addWatermarkBtn.addEventListener('click', addWatermarkToPDF);
    </script>
</body>
</html>
